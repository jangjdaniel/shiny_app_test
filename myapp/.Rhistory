unweighted_gee_vcov["treatment", "treatment:time_2"] #the covariance
# this is fixed for the purposes of OARS (i.e. 6 timepoints, there is a magic number here)
gee_ate_variance_calculator <- function(glmgee_object) {
#extract the variance-covariance matrix
glmgee_vcov <- glmgee_object |> vcov()
#now initialize some things
variance_vector <- c()
baseline_variance <- glmgee_vcov["treatment", "treatment"]
interaction_effects <- c("treatment:time_2", "treatment:time_3",
"treatment:time_4", "treatment:time_5",
"treatment:time_6")
for(i in 1:length(interaction_effects)) {
interaction_variance <- glmgee_vcov[interaction_effects[i], interaction_effects[i]]
covariance <- glmgee_vcov["treatment", interaction_effects[i]]
variance <- baseline_variance + interaction_variance - (2*covariance) #mathematical property
variance_vector[i] <- variance #store in vector
}
return(variance_vector)
}
#| eval: false
gee_ate_variance_calculator(unweighted_gee_oars_unstructured)
unweighted_gee_vcov["treatment", "treatment"] + unweighted_gee_vcov["treatment:time_2", "treatment:time_2"] - (2*unweighted_gee_vcov["treatment", "treatment:time_2"])
unweighted_gee_vcov
gee_ate_variance_calculator(unweighted_gee_oars_unstructured) |> sqrt()
gee_ate_variance_calculator(unweighted_gee_oars_unstructured)

library(tidyverse)
library(tidyselect)
library(haven) # to read SAS files
library(readxl) # to read xlsx files
library(gtsummary) # nice count visualizations
library(forcats) # a specific data wrangling issue
library(survival)
library(ggsurvfit)
oars_worst_pain_gee <- readRDS("oars_worst_pain_wrangled.rds") |>
pivot_longer(c(tgroup_day_1pm, tgroup_day_2am, tgroup_day_2pm, tgroup_day_3am, tgroup_day_3pm, tgroup_day_4am),
names_to = "time",
values_to = "treatment") |>
mutate(worst_pain = case_when(
time == "tgroup_day_1pm" ~ day_1pm_worst_pain,
time == "tgroup_day_2am" ~ day_2am_worst_pain,
time == "tgroup_day_2pm" ~ day_2pm_worst_pain,
time == "tgroup_day_3am" ~ day_3am_worst_pain,
time == "tgroup_day_3pm" ~ day_3pm_worst_pain,
time == "tgroup_day_4am" ~ day_4am_worst_pain)) |> #also create time indicator lol
mutate(time_indicator = case_when(
time == "tgroup_day_1pm" ~ 1,
time == "tgroup_day_2am" ~ 2,
time == "tgroup_day_2pm" ~ 3,
time == "tgroup_day_3am" ~ 4,
time == "tgroup_day_3pm" ~ 5,
time == "tgroup_day_4am" ~ 6,
)) |>
mutate(time_2 = ifelse(time_indicator == 2, 1, 0),
time_3 = ifelse(time_indicator == 3, 1, 0),
time_4 = ifelse(time_indicator == 4, 1, 0),
time_5 = ifelse(time_indicator == 5, 1, 0),
time_6 = ifelse(time_indicator == 6, 1, 0)) |>
dplyr::select(study_id, treatment, stop_time, switch_time, time_indicator, time_2, time_3, time_4, time_5, time_6,
worst_pain, gender, rochester_indicator, chicago_indicator, michigan_indicator, rutgers_indicator,
current_age_years, smoking_preop) # now create a previous pain variable
# check what this looks like
oars_worst_pain_gee |> head()
library(gee)
oars_worst_pain_unweighted_gee <- oars_worst_pain_gee |>
mutate(numbered_ids = as.numeric(as.factor(study_id))) #for some reason ids need to be doubles, not factors or characters :/
oars_formula <- formula(worst_pain ~ treatment + time_2 + time_3 + time_4 + time_5 + time_6 + treatment*time_2 + treatment*time_3 + treatment*time_4 + treatment*time_5 + treatment*time_6 + gender + rochester_indicator+ chicago_indicator + michigan_indicator + rutgers_indicator)
unweighted_gee_oars_independence <- gee(oars_formula,
data = oars_worst_pain_unweighted_gee,
id = numbered_ids,
family = gaussian,
corstr = "unstructured")
unweighted_gee_oars_independence |> summary()
unweighted_gee_oars_unstructured <- gee(oars_formula,
data = oars_worst_pain_unweighted_gee,
id = numbered_ids,
family = gaussian,
corstr = "unstructured")
unweighted_gee_oars_unstructured |> summary()
